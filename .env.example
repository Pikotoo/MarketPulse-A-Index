# MarketPulse 环境变量配置
# 复制为 .env 并根据需要修改

# ── 数据路径 ─────────────────────────────────────────────
# 宏观/行业数据根目录
# DATA_ROOT=H:\数据大全

# ── API 配置 ─────────────────────────────────────────────
API_PORT=8898
API_HOST=0.0.0.0

# ── AI 配置 ─────────────────────────────────────────────
# DeepSeek API Key（用于仪表盘 AI 对话功能）
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── 仪表盘配置 ───────────────────────────────────────────
# 仪表盘专用只读 API Key（可选，不设置则使用默认值）
# DASHBOARD_KEY=mp-806fac606a6e1ce607ce158175087ca9
