# MarketPulse .gitignore
# ========================

# ── 敏感数据（绝对不能提交）──
data/
backups/
.env
*.db
*.db-journal
*.db-wal
*.db-shm

# ── 原始数据文件 ──
data_source/

# ── Python ──
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── 虚拟环境 ──
venv/
.venv/
env/

# ── IDE / 编辑器 ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── 测试 ──
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── 日志 ──
logs/
*.log

# ── 操作系统 ──
.DS_Store
Thumbs.db
desktop.ini

# ── 临时文件 ──
tmp/
temp/
*.tmp
